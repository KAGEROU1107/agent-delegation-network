{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adn-release-proof-v1",
  "title": "ADN release proof manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_tail",
    "contract_version",
    "build_commit",
    "rustc_version",
    "trusted_issuer",
    "tenant_did",
    "build_config_id",
    "local_wasm_sha256",
    "registration_status",
    "registered_at",
    "remote_contract_id",
    "raw_registration_response_digest",
    "raw_registration_response_path",
    "first_invocation_digest",
    "first_invocation_path",
    "t3n_evidence_digest",
    "t3n_evidence_path",
    "operator_public_key",
    "manifest_digest"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "adn-release-proof-v1"},
    "contract_tail": {"type": "string"},
    "contract_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "build_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "rustc_version": {"type": "string"},
    "trusted_issuer": {"type": "string"},
    "tenant_did": {"type": "string"},
    "build_config_id": {"type": "string"},
    "local_wasm_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "registration_status": {"type": "string", "enum": ["registered", "pending", "failed"]},
    "registered_at": {"type": "string"},
    "remote_contract_id": {"type": "integer"},
    "raw_registration_response_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_registration_response_path": {"type": "string"},
    "first_invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "first_invocation_path": {"type": "string"},
    "t3n_evidence_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "t3n_evidence_path": {"type": "string"},
    "operator_public_key": {"type": "string"},
    "manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
