# Terminal 3 testnet credentials
T3N_API_KEY=0x_YOUR_T3N_API_KEY_HERE
TERMINAL3_API_KEY=0x_YOUR_T3N_API_KEY_HERE

# Optional: LLM API key for live text generation in feature demos
