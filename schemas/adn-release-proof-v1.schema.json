{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/adn/schemas/adn-release-proof-v1.schema.json",
  "title": "ADN release proof manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_tail",
    "contract_version",
    "build_commit",
    "rustc_version",
    "trusted_issuer",
    "tenant_did",
    "build_config_id",
    "local_wasm_sha256",
    "registration_status",
    "remote_contract_id",
    "raw_registration_response_digest",
    "raw_registration_response_path",
    "first_invocation_digest",
    "first_invocation_path",
    "t3n_evidence_digest",
    "t3n_evidence_path",
    "operator_public_key",
    "manifest_digest"
  ],
  "properties": {
    "schema_version": { "const": "adn-release-proof-v1" },
    "contract_tail": { "const": "adn-processor" },
    "contract_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "build_commit": { "type": "string", "minLength": 7 },
    "rustc_version": { "type": "string", "minLength": 1 },
    "trusted_issuer": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "tenant_did": { "type": "string", "pattern": "^did:t3n:.+" },
    "build_config_id": { "type": "string", "pattern": "^adn-build-[0-9a-fA-Fa-z_-]+" },
    "local_wasm_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "registration_status": { "enum": ["pending", "registered"] },
    "registered_at": { "type": "string", "minLength": 1 },
    "remote_contract_id": { "type": "integer", "minimum": 1 },
    "raw_registration_response_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "raw_registration_response_path": { "const": "registration_response.json" },
    "first_invocation_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "first_invocation_path": { "const": "invocation_receipt.json" },
    "t3n_evidence_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "t3n_evidence_path": { "const": "t3n_evidence.json" },
    "operator_public_key": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "manifest_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
